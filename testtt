    local function sellHorsesOnce()
        identifiers = {} -- Clear existing identifiers for a fresh scan
        scanInventoryForHorses()
        loadCorrectRemoteFromCamera()
        fireDetectedRemoteForHorses()
    end

    -- === Locked Horse Fix Functions ===
    local function fireAllRemotes(args)
        for i = 0, 100 do
            local remoteEvent = functionsFolder:FindFirstChild(tostring(i))
            if remoteEvent then
                pcall(function()
                    remoteEvent:FireServer(unpack(args))
                end)
            end
        end
    end

    local function followAndPickup(modelName)
        fireAllRemotes({"Use", modelName, "Follow"})
        task.wait(0.2)
        fireAllRemotes({"Use", modelName, "Pickup"})
    end

    local function logLockedHorse(item)
        if item.Name:match("^%b{}$") then
