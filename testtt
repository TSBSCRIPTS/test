                logLockedHorse(item)
            end
        end)
        if not success then
            -- -- -- warn("Error scanning inventory: " .. err)
        end
    end

    local function runFixScriptOnce()
        scanInventoryForLockedHorses()
    end

    -- Infinite loop to sell horses and fix locked horses
    while true do
        sellHorsesOnce()
        wait(2)
        runFixScriptOnce()
        wait(56)
    end
end

