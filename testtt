local function efAddNoise(vec, amt)
    return vec + Vector3.new(
        (math.random() - 0.5) * amt,
        (math.random() - 0.5) * amt,
        (math.random() - 0.5) * amt
    )
end

local function efSmoothVel(last, new)
    return last:Lerp(new, 0.20)
