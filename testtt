-- Two-segment tween with random midpoint noise (anti-cheat friendly approach)
local function tweenToTarget(targetCF)
    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    local startPos = root.Position
    local endPos   = targetCF.Position
    local dist     = (startPos - endPos).Magnitude
    if dist < 2 then return end

    local speed    = 36
    local half     = (dist / speed) / 2

    local midPos = (startPos + endPos) / 2 + Vector3.new(
        math.random(-7, 7), math.random(1, 4), math.random(-7, 7)
    )
    local finalNoise = Vector3.new(
        math.random(-3, 3), math.random(-1, 2), math.random(-3, 3)
    )

    local tween1 = EFTweenService:Create(root,
        TweenInfo.new(half, Enum.EasingStyle.Linear),
        { CFrame = CFrame.new(midPos) }
    )
    local tween2 = EFTweenService:Create(root,
        TweenInfo.new(half, Enum.EasingStyle.Linear),
        { CFrame = CFrame.new(endPos + finalNoise) }
    )

    local function safeWait(tw)
        local done = false
        tw.Completed:Connect(function() done = true end)
        efActiveTween = tw
        tw:Play()
        while not done and _G.isScriptRunning do task.wait() end
        efActiveTween = nil
    end

    safeWait(tween1)
    if not _G.isScriptRunning then return end
    safeWait(tween2)
end

-- Follow horse using MoveTo (physics-based, no CFrame snapping)
local function followHorse(horsePart)
    _G.followingTarget = true
    local lastVel = Vector3.zero
    efLastTweenTime = tick()

    while _G.isScriptRunning and horsePart and horsePart.Parent do
        local char = player.Character
        local hum  = char and char:FindFirstChild("Humanoid")
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if not hum or not root then break end

        local raw = horsePart.Position - root.Position
        if raw.Magnitude < 3 then
            task.wait(0.1)
        else
            local vel = efSmoothVel(lastVel, raw)
            vel = efAddNoise(vel.Unit * 3, 0.45)
            hum:MoveTo(root.Position + vel)
            hum.MoveToFinished:Wait(0.1)
            lastVel = vel
        end

        -- Periodic re-tween to close any gap that drifted open
        if tick() - efLastTweenTime >= 10 then
            efLastTweenTime = tick()
            tweenToTarget(horsePart.CFrame)
        end
    end

    _G.followingTarget = false
end

