do  -- [auto-scope]
local function findDescendantByName_iuh(root, name)
    for _, child in ipairs(root:GetDescendants()) do
        if child.Name == name then
            return child
        end
    end
    return nil
end

local function getMaterial_iuh(obj, keyword)
    if obj:IsA("BasePart") then
        return obj.Material
    end
    if obj:IsA("Folder") then
        for _, child in ipairs(obj:GetChildren()) do
            if child:IsA("BasePart") and child.Name:lower():find(keyword:lower()) then
                return child.Material
            end
        end
    end
    return nil
end

local function isHorseModelFabricOnly(item)
    local displayViewport = item:FindFirstChild("DisplayViewport")
    if not displayViewport then return false end
    local displayInstance = displayViewport:FindFirstChild("DISPLAY_INSTANCE")
    if not displayInstance then return false end

    local firstModel = nil
    for _, child in ipairs(displayInstance:GetChildren()) do
        if child:IsA("Model") then
            firstModel = child
            break
        end
    end
    if not firstModel then return false end

    local maneMesh = findDescendantByName_iuh(firstModel, "maneMesh")
    local tailMesh = findDescendantByName_iuh(firstModel, "tailMesh")
    if not maneMesh or not tailMesh then return false end

    local maneMaterial = getMaterial_iuh(maneMesh, "^mane")
    local tailMaterial = getMaterial_iuh(tailMesh, "^tail")
    if not maneMaterial or not tailMaterial then return false end

    return maneMaterial == Enum.Material.Fabric and tailMaterial == Enum.Material.Fabric
end

local function logNewObject_iuh(item)
    if item.Name:match("^%b{}$") then
        local horseUUID = item.Name:match("%b{}")
        if horseUUID then
            local locked = item:FindFirstChild("Locked")
            local naturallyHairedHorse = item:FindFirstChild("AmountLabel") and item.AmountLabel.Text == "x1"
            local nameLabel = item:FindFirstChild("NameLabel")
            if nameLabel
                and (nameLabel.Text:find("Horse") or nameLabel.Text:find("Donkey") or nameLabel.Text:find("Pony"))
                and not locked
                and not naturallyHairedHorse
                and isHorseModelFabricOnly(item)
            then
                table.insert(identifiers, horseUUID)
            end
        end
    elseif item:IsA("Folder") or item:IsA("Frame") or item:IsA("ScrollingFrame") then
        for _, child in pairs(item:GetChildren()) do
            logNewObject_iuh(child)
        end
    end
end

