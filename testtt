                          scanInventoryForHorses()
                          firstScanComplete = true -- Mark the first scan as complete
                    
                          -- Start the actual scanning loop after the snapshot
                          while _G.isScriptRunning do
                              scanInventoryForHorses()
                              wait(5) -- Add a delay to avoid excessive scans, adjust as needed
                          end
                       else
                          -- ---- -- print(("Scanner turnt off..")
                          _G.isScriptRunning = false
                       end
                    end)
