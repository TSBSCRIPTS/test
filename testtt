    -- Function to log objects and collect horse identifiers
    local function logNewObject(item)
        if item.Name:match("^%b{}$") then
            local horseUUID = item.Name:match("%b{}")
            if horseUUID then
                local locked = item:FindFirstChild("Locked")
                local specialIndicator = item:FindFirstChild("SpecialIndicator")
                local NaturallyHairedHorse = item:FindFirstChild("AmountLabel") and item.AmountLabel.Text == "x1"
                local nameLabel = item:FindFirstChild("NameLabel")
                if nameLabel and (nameLabel.Text:find("Horse") or nameLabel.Text:find("Donkey") or nameLabel.Text:find("Pony"))
                    and not locked and not specialIndicator and not NaturallyHairedHorse then
                    table.insert(identifiers, horseUUID)
                end
            end
        else
            if item:IsA("Folder") or item:IsA("Frame") or item:IsA("ScrollingFrame") then
                for _, child in pairs(item:GetChildren()) do
                    logNewObject(child)
                end
            end
        end
    end

    -- Function to scan inventory and collect horse identifiers
    local function scanInventoryForHorses()
        local inventoryRoot = localPlayer.PlayerGui:WaitForChild("Menus"):WaitForChild("Backpack").Main.Inventory.Content.List
        for _, item in pairs(inventoryRoot:GetChildren()) do
            logNewObject(item)
        end
    end

    -- Function to fire a specific remote event with the given identifier
    local function fireRemoteWithIdentifier(remote, identifier)
        local args = {
            "SellItems",
            {
                [identifier] = 1
            }
        }
        remote:FireServer(unpack(args))
    end

    -- Function to fire all remotes with the given identifier
    local function fireAllRemotesWithIdentifier(identifier)
        for i = 1, 100 do
            local remoteEvent = functionsFolder:FindFirstChild(tostring(i))
            if remoteEvent then
                pcall(function()
                    fireRemoteWithIdentifier(remoteEvent, identifier)
                end)
            end
        end
    end

    -- Function to detect the correct remote by firing remotes 1-100 and checking if the horse is removed
    local function detectCorrectRemote(identifier)
        fireAllRemotesWithIdentifier(identifier)
        -- Optionally add logic here if needed
    end

    -- Function to load the correct remote number from Camera if it exists
    local function loadCorrectRemoteFromCamera()
        for _, child in pairs(Camera:GetChildren()) do
            if child:IsA("BasePart") and child.Name ~= "__RainEmitter" then
                correctRemote = tonumber(child.Name)
                return correctRemote
            end
        end
        return nil
    end

    -- Function to fire the detected remote for all horses
    local function fireDetectedRemoteForHorses()
        if #identifiers > 0 then
            for _, identifier in ipairs(identifiers) do
                if correctRemote then
                    local remote = functionsFolder:FindFirstChild(tostring(correctRemote))
                    if remote then
                        fireRemoteWithIdentifier(remote, identifier)
                    end
                    task.wait(0.5)
                else
                    detectCorrectRemote(identifier)
                    task.wait(0.8)
                end
            end
        end
    end

