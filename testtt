--// Helper: equip treasure shovel
local function equipTreasureShovel()
    local inventory = data.GetLocal({"inventory"})
    if not inventory then
        return
    end

    for slot, item in pairs(inventory) do
        if item then
            local info = refs.Items.GetInfo(item.id)
            if info and info.name then
                local lowerName = info.name:lower()
                if lowerName:find("treasure") or lowerName:find("shovel") then
                    utilities.Network:FireServer("Inventory", "Use", slot, "Equip")
                    break
                end
            end
        end
    end
end

--// Helper: tween to position, then run a callback when arrived
local function tweenToPositionAndThen(targetPos, onArrive)
    local rootPart = getRootPart()
    if not rootPart then
        return
    end

    local finalPos = targetPos + ABOVE_GROUND_OFFSET
    local distance = (finalPos - rootPart.Position).Magnitude
    local travelTime = math.max(distance / MOVE_SPEED, 0.5)

    local tween = TweenService:Create(
        rootPart,
        TweenInfo.new(travelTime, Enum.EasingStyle.Linear),
        { CFrame = CFrame.new(finalPos) }
    )

    tween:Play()
    tween.Completed:Wait()

    if onArrive then
        onArrive()
    end
end

