local refs = require(game.ReplicatedStorage.References)
local travelHandler = require(refs.PlayerScripts.Secondary.TravelHandler)

-- Keep track of running loops per toggle name
local travelLoops = {}

local function tryTravel(island)
    local success, message = travelHandler.CanTravel(island, nil, true)
    if success then
        travelHandler.Travel(island)
        -- -- -- print("Traveled to:", island)
        return true
    else
        -- -- -- warn(("Cannot travel to %s: %s"):format(island, tostring(message)))
        return false
    end
end

-- steps = array of { island = "Forest Island", waitTime = 10, after = function() ... end }
local function setTravelToggle(key, enabled, steps)
    -- stop any existing loop
    if not enabled then
        travelLoops[key] = false
        return
    end

    -- mark this loop as running
    travelLoops[key] = true

    task.spawn(function()
        while travelLoops[key] do
            for _, step in ipairs(steps) do
                if not travelLoops[key] then break end

                if step.island then
                    tryTravel(step.island)
                end

                -- optional hook after traveling to this island
                if step.after then
                    step.after()
