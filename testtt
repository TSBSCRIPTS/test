local Islands = workspace:WaitForChild("Islands")

local TARGET_NAME = "Horse Sale Barn"

-- Marks islands we've already set up, to prevent duplicate connections
local hooked = setmetatable({}, { __mode = "k" })

local function deleteIfTarget(inst)
	-- Ensure it's still parented somewhere under Islands (safety)
	if inst == nil or inst.Parent == nil then return end
	if not inst:IsDescendantOf(Islands) then return end

	if inst.Name == TARGET_NAME then
		inst:Destroy()
	end
end

local function monitorIsland(island)
	if hooked[island] then return end
	hooked[island] = true

	-- Delete existing targets already inside the island
	for _, desc in ipairs(island:GetDescendants()) do
		deleteIfTarget(desc)
	end

	-- Watch only for new targets that appear under this island
	island.DescendantAdded:Connect(function(desc)
		deleteIfTarget(desc)
	end)
end

-- Hook existing islands
for _, island in ipairs(Islands:GetChildren()) do
	monitorIsland(island)
end

-- Hook future islands
Islands.ChildAdded:Connect(function(island)
	monitorIsland(island)
end)





