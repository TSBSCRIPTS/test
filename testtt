do  -- [auto-scope]
                    local folderName = "TSB HUB SETTNINGS"
                    local fileName = "webhook.txt"
                    
                    -- Function to check if the folder exists and handle the file
                    local function checkFolderAndFile()
                        if isfolder(folderName) then
                            local filePath = folderName .. "\\" .. fileName
                            if not isfile(filePath) then
                                writefile(filePath, "")
                            end
                            local url = readfile(filePath)
                            if url == "" then
                                -- -- -- warn("Webhook URL is empty.")
                                return nil
                            end
                            return url
                        else
                            local fallbackFilePath = fileName
                            if not isfile(fallbackFilePath) then
                                writefile(fallbackFilePath, "")
                            end
                            local url = readfile(fallbackFilePath)
                            if url == "" then
                                -- -- -- warn("Fallback Webhook URL is empty.")
                                return nil
                            end
                            return url
                        end
                    end
                    
                    -- Function to send an embedded message using an executor
                    function SendMessageEMBED(url, embed, pingEveryone)
                        if not url:match("^https?://") then
                            return
                        end
                    
                        local data = {
                            ["content"] = pingEveryone and "@everyone" or nil, -- Ping everyone if necessary
                            ["embeds"] = {
                                {
                                    ["title"] = embed.title,
                                    ["description"] = embed.description,
                                    ["color"] = embed.color,
                                    ["fields"] = embed.fields,
                                    ["footer"] = {
                                        ["text"] = embed.footer.text
                                    }
                                }
                            }
                        }
                    
                        request({
                            Url = url,
                            Method = "POST",
                            Headers = {
                                ["Content-Type"] = "application/json"
                            },
                            Body = game:GetService("HttpService"):JSONEncode(data)
                        })
                    end
                    
                    -- Function to log newly added horses in the inventory (ignore existing horses on first scan)
                    local function logNewObject(item)
                        -- Check if the item is a TextButton or TextFrame representing a horse
                        if item:IsA("TextButton") or item:IsA("TextFrame") then
                            -- Find the NameLabel (Horse Name) instead of UUID
                            local nameLabel = item:FindFirstChild("NameLabel")
                            if nameLabel and nameLabel.Text then
                                local horseName = nameLabel.Text -- The name of the horse (e.g., "Quarter Horse")
                    
                                -- On the first scan, populate the identifiers table without sending webhooks
                                if not firstScanComplete then
                                    identifiers[horseName] = true -- Mark this horse as "already in inventory"
                                    return
                                end
                    
                                -- If it's a new horse, log it
                                if not identifiers[horseName] then
                                    local specialIndicator = item:FindFirstChild("SpecialIndicator")
                    
                                    if specialIndicator then
                                        identifiers[horseName] = true -- Mark this horse as logged
                    
                                        -- Check the color of the SpecialIndicator
                                        local color = specialIndicator.BackgroundColor3
                    
                                        -- Unique Coat Horse (Color: 255, 108, 89)
                                        if color == Color3.fromRGB(255, 108, 89) then
                                            local embed = {
                                                ["title"] = "Stored Unique Coat Horse!",
                                                ["description"] = "A unique coat horse has been stored in your inventory: " .. horseName,
                                                ["color"] = 16744448, -- Orange color for unique coat horses
                                                ["fields"] = {
                                                    {
                                                        ["name"] = "Horse Name",
                                                        ["value"] = horseName
                                                    }
                                                },
                                                ["footer"] = {
                                                    ["text"] = "Unique coat horse detected."
                                                }
                                            }
                    
                                            local url = checkFolderAndFile()
                                            if url then
                                                SendMessageEMBED(url, embed, false) -- No ping
                                            else
                                                -- -- -- warn("Webhook URL is missing.")
                                            end
                    
                                        -- Rare IUH Horse (Color: 255, 87, 137)
                                        elseif color == Color3.fromRGB(255, 87, 137) then
                                            local embed = {
                                                ["title"] = "IUH Stored!",
                                                ["description"] = "An IUH horse has been stored in your inventory: " .. horseName,
                                                ["color"] = 16711935, -- Pink color for rare horses
                                                ["fields"] = {
                                                    {
                                                        ["name"] = "Horse Name",
                                                        ["value"] = horseName
                                                    }
                                                },
                                                ["footer"] = {
                                                    ["text"] = "Rare IUH horse detected."
                                                }
                                            }
                    
                                            local url = checkFolderAndFile()
                                            if url then
                                                SendMessageEMBED(url, embed, true) -- Ping everyone
                                            else
                                                -- -- -- warn("Webhook URL is missing.")
                                            end
                                        end
                                    end
                                end
                            end
                        else
                            -- Recursively check children of non-TextButton/TextFrame objects
                            for _, child in pairs(item:GetChildren()) do
                                logNewObject(child)
                            end
                        end
                    end
                    
                    -- Function to scan inventory and collect horse identifiers (only new horses)
                    local function scanInventoryForHorses()
                        local inventoryRoot = localPlayer.PlayerGui:WaitForChild("Menus"):WaitForChild("Backpack").Main.Inventory.Content.List
                        for _, item in pairs(inventoryRoot:GetChildren()) do
                            -- Recursively scan for horses and log new ones
                            logNewObject(item)
                        end
                    end
                    
                    -- Toggle button to turn on/off the horse webhook scanning
                    local toggle = sector3.element('Toggle', 'Webhook (Useless)', false, function(v)
                       if v.Toggle then
