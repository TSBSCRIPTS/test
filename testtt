-- Function to calculate time for the player to reach the target position based on their WalkSpeed and speed control
function Time(targetPos)
    local distance = (targetPos - player.Character.HumanoidRootPart.Position).Magnitude
    local walkSpeed = player.Character:FindFirstChildOfClass("Humanoid").WalkSpeed
    local adjustedSpeed = walkSpeed * speedControl
    local time = distance / adjustedSpeed
    return time
end

-- Function to tween the player to a specific position using the updated tweening method
local function tp(x, y, z)
    local targetPosition = Vector3.new(x, y, z)
    local timeToReach = Time(targetPosition)
    
    local tweenInfo = TweenInfo.new(timeToReach, Enum.EasingStyle.Quad)
    
    local tween, err = pcall(function()
        local cframe = CFrame.new(targetPosition)
        local tween = tweenService:Create(player.Character["HumanoidRootPart"], tweenInfo, { CFrame = cframe })
        tween:Play()
    end)
    
    if not tween then
