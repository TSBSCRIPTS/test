local function doFailsafeSequence()
    if restartingFromFailsafe then return end
    restartingFromFailsafe = true

    -- If we never detected the training type, try reading it now before resetting
    if not selectedTrainingId or not selectedTrainingType then
        local id, tType = getCurrentTrainingInfoFromGui()
        if id and tType then
            selectedTrainingId = id
            selectedTrainingType = tType
        end
    end

    if currentPlayerTween then
        currentPlayerTween:Cancel()
        currentPlayerTween = nil
    end
    if currentTargetTween then
        currentTargetTween:Cancel()
        currentTargetTween = nil
    end

    if not character or not humanoidRootPart then
        updateCharacter()
    end

    local targetHumanoidRootPart = findTargetHumanoidRootPart()
    local resetCFrame = getResetCFrame()

    local tweenInfo = TweenInfo.new(
        3,
        Enum.EasingStyle.Linear,
        Enum.EasingDirection.Out
    )

    local goal = { CFrame = resetCFrame }

    local playerTween
    if humanoidRootPart then
        playerTween = TweenService:Create(humanoidRootPart, tweenInfo, goal)
        playerTween:Play()
    end

    if targetHumanoidRootPart then
        local horseTween = TweenService:Create(targetHumanoidRootPart, tweenInfo, goal)
        horseTween:Play()
    end

    local function afterArrived()
        local horseHRP = findTargetHumanoidRootPart()
        local horseHumanoid = horseHRP and horseHRP.Parent:FindFirstChildOfClass("Humanoid")
        local savedSpeed = horseHumanoid and horseHumanoid.WalkSpeed or 16

        if horseHRP then
            horseHRP.Anchored = true
        end
        if horseHumanoid then
            horseHumanoid.WalkSpeed = 0
        end

        task.delay(0.5, function()
            redoTrainingSetup()

            task.delay(3, function()
                pressEKey()

                task.delay(1.5, function()
                    if horseHRP then
                        horseHRP.Anchored = false
                    end
                    if horseHumanoid then
                        horseHumanoid.WalkSpeed = savedSpeed
                    end

                    restartingFromFailsafe = false
                    if autoTrainRequested then
                        startAutoTrain()
                    end
                end)
            end)
        end)
    end

    if playerTween then
        playerTween.Completed:Connect(function()
            afterArrived()
        end)
    else
        afterArrived()
    end
end

startAutoTrain = function()
    if autoTrainTask == nil and autoTrainRequested then
        autoTrainEnabled = true
        markerMissingTime = 0
        noHorseTime = 0
        selectedTrainingId = nil
        selectedTrainingType = nil

        task.delay(5, function()
            if autoTrainEnabled and autoTrainRequested then
                local id, tType = getCurrentTrainingInfoFromGui()
                selectedTrainingId = id
                selectedTrainingType = tType
            end
        end)

        autoTrainTask = task.spawn(function()
            local ok, err = pcall(function()
                local needFailsafe = false

                while autoTrainEnabled do
                    if not character or not humanoidRootPart then
                        updateCharacter()
                    end

                    local workspaceService = game:GetService("Workspace")
                    local checkpointMarker = workspaceService:FindFirstChild("CheckpointMarker")
                    local markerPart = checkpointMarker and checkpointMarker:FindFirstChild("Marker")

                    if checkpointMarker and markerPart then
                        markerMissingTime = 0

                        local targetHumanoidRootPart = findTargetHumanoidRootPart()

                        if targetHumanoidRootPart then
                            noHorseTime = 0

                            local tweenInfo = TweenInfo.new(
                                2,
                                Enum.EasingStyle.Linear,
                                Enum.EasingDirection.Out
                            )

                            local tweenGoal = { CFrame = markerPart.CFrame }

                            currentPlayerTween = TweenService:Create(humanoidRootPart, tweenInfo, tweenGoal)
                            currentTargetTween = TweenService:Create(targetHumanoidRootPart, tweenInfo, tweenGoal)

                            currentPlayerTween:Play()
                            currentTargetTween:Play()

                            local completed = false

                            currentPlayerTween.Completed:Connect(function()
                                completed = true
                            end)

                            currentTargetTween.Completed:Connect(function()
                            end)

                            while not completed and autoTrainEnabled do
                                task.wait(0.05)
                            end

                            currentPlayerTween = nil
                            currentTargetTween = nil
                        else
                            local dt = task.wait(0.5)
                            noHorseTime += dt
                            if noHorseTime >= noHorseThreshold then
                                needFailsafe = true
                                break
                            end
                        end
                    else
                        local dt = task.wait(0.5)
                        markerMissingTime = markerMissingTime + dt

                        if markerMissingTime >= markerMissingThreshold then
                            needFailsafe = true
                            break
                        end
                    end

                    if not autoTrainEnabled then
                        break
                    end
                end

                autoTrainTask = nil
                autoTrainEnabled = false

                if needFailsafe and autoTrainRequested then
                    doFailsafeSequence()
                end
            end)

            if not ok then
                autoTrainTask = nil
                autoTrainEnabled = false
            end
        end)
    end
end

